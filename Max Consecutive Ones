#🚀485. Max Consecutive Ones
class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        count1=0
        maxcount=0
        for i in range(len(nums)):
            if (nums[i]==1):
                count1=count1+1
            else:
                if(count1>maxcount):
                    maxcount=count1
                count1=0
        if(count1>maxcount):
            maxcount=count1
        return maxcount
